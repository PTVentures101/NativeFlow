# === NativeVibe Environment Variables ===

# Google Gemini API (required)
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Upstash Redis (optional — falls back to in-memory rate limiting if not set)
# Create a free database: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ElevenLabs (optional — for Audio Mode in a future sprint)
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
